# ================================================
#   HARDIK PORTFOLIO BACKEND — ENV CONFIGURATION
# ================================================
# Copy this file to .env and fill in your values.
# NEVER commit your actual .env to Git.

# ── SERVER ──────────────────────────────────────
PORT=5000
NODE_ENV=development
# Allowed frontend origins (comma-separated)
CLIENT_ORIGIN=http://localhost:5173,https://yourportfolio.com

# ── DATABASE (MySQL) ─────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=portfolio_db
DB_CONNECTION_LIMIT=10

# ── JWT (Admin Auth) ─────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_min_32_chars
JWT_EXPIRES_IN=7d

# ── EMAIL (Nodemailer / Gmail SMTP) ─────────────
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=hardik0626@gmail.com
# Use Gmail App Password (not your main password)
# Go to: Google Account → Security → App Passwords
MAIL_PASS=hardik123@
MAIL_FROM=hardik0626@gmail.com
# Where contact form emails are delivered
MAIL_TO=hardik0626@gmail.com

# ── RATE LIMITING ────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
CONTACT_RATE_LIMIT_MAX=5

# ── ADMIN ────────────────────────────────────────
ADMIN_EMAIL=hardik0626@gmail.com
# bcrypt hash of admin password (generate with scripts/hash-password.js)
ADMIN_PASSWORD_HASH=$2b$12$PLACEHOLDER_REPLACE_WITH_REAL_HASH

# ── FILE UPLOAD ──────────────────────────────────
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=5
